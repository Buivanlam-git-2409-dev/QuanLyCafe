@model IEnumerable<MyCafe.Web.Models.CongDung>

@{
    ViewData["Title"] = "Quản Lý Công Dụng";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1>@ViewData["Title"]</h1>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-lg"></i> Thêm Công Dụng
            </a>
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Mã Công Dụng</th>
                        <th>Tên Công Dụng</th>
                        <th class="text-center">Hành Động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><strong>@Html.DisplayFor(modelItem => item.MaCongDung)</strong></td>
                            <td>@Html.DisplayFor(modelItem => item.TenCongDung)</td>
                            <td class="text-center">
                                <a asp-action="Details" asp-route-id="@item.MaCongDung" class="btn btn-sm btn-info" title="Chi Tiết">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@item.MaCongDung" class="btn btn-sm btn-warning" title="Chỉnh Sửa">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.MaCongDung" class="btn btn-sm btn-danger" title="Xóa">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info" role="alert">
            <i class="bi bi-info-circle"></i> Không có công dụng nào.
        </div>
    }
</div>
