@model MyCafe.Web.Models.HoaDonBan

@{
    ViewData["Title"] = "Lập Hóa Đơn Bán Hàng";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-6 offset-md-3">
            <div class="card shadow">
                <div class="card-header bg-success text-white">
                    <h3 class="mb-0"><i class="bi bi-file-earmark-plus"></i> @ViewData["Title"]</h3>
                </div>
                <div class="card-body">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        
                        <div class="mb-3">
                            <label asp-for="MaHDB" class="form-label fw-bold">Số Hóa Đơn</label>
                            <input asp-for="MaHDB" class="form-control" placeholder="HDB001..." />
                            <span asp-validation-for="MaHDB" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="NgayBan" class="form-label fw-bold">Ngày Giờ Bán</label>
                            <input asp-for="NgayBan" type="datetime-local" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" />
                            <span asp-validation-for="NgayBan" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="MaNV" class="form-label fw-bold">Nhân Viên Lập</label>
                            <select asp-for="MaNV" class="form-select" asp-items="ViewBag.MaNV">
                                <option value="">-- Chọn Nhân Viên --</option>
                            </select>
                            <span asp-validation-for="MaNV" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="MaKH" class="form-label fw-bold">Khách Hàng</label>
                            <select asp-for="MaKH" class="form-select" asp-items="ViewBag.MaKH">
                                <option value="">-- Chọn Khách Hàng --</option>
                            </select>
                            <span asp-validation-for="MaKH" class="text-danger"></span>
                        </div>

                        <div class="alert alert-info py-2">
                            <i class="bi bi-info-circle"></i> Sau khi nhấn "Tiếp Tục", bạn sẽ được chuyển đến trang thêm chi tiết sản phẩm.
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-action="Index" class="btn btn-secondary me-md-2">Hủy Bỏ</a>
                            <button type="submit" class="btn btn-success px-4">Tiếp Tục <i class="bi bi-arrow-right"></i></button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
