@model MyCafe.Web.Models.HoaDonBan

@{
    ViewData["Title"] = "Cập Nhật Chi Tiết Hóa Đơn";
}

<div class="container-fluid mt-4">
    <div class="row">
        <!-- Master Info -->
        <div class="col-md-4">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-info-circle"></i> Thông Tin Hóa Đơn</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <input type="hidden" asp-for="MaHDB" />
                        
                        <div class="mb-3">
                            <label class="form-label fw-bold">Số Hóa Đơn</label>
                            <input class="form-control bg-light" value="@Model.MaHDB" disabled />
                        </div>

                        <div class="mb-3">
                            <label asp-for="NgayBan" class="form-label fw-bold">Ngày Bán</label>
                            <input asp-for="NgayBan" type="datetime-local" class="form-control" />
                            <span asp-validation-for="NgayBan" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="MaNV" class="form-label fw-bold">Nhân Viên</label>
                            <select asp-for="MaNV" class="form-select" asp-items="ViewBag.MaNV"></select>
                            <span asp-validation-for="MaNV" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="MaKH" class="form-label fw-bold">Khách Hàng</label>
                            <select asp-for="MaKH" class="form-select" asp-items="ViewBag.MaKH"></select>
                            <span asp-validation-for="MaKH" class="text-danger"></span>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary">Lưu Thay Đổi Thông Tin</button>
                        </div>
                    </form>
                </div>
                <div class="card-footer bg-light">
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="fw-bold">TỔNG CỘNG:</span>
                        <span class="text-danger fw-bold fs-4">@(Model.TongTien?.ToString("N0") ?? "0") VNĐ</span>
                    </div>
                </div>
            </div>
            <a asp-action="Index" class="btn btn-secondary w-100"><i class="bi bi-arrow-left"></i> Quay Lại Danh Sách</a>
        </div>

        <!-- Detail Management -->
        <div class="col-md-8">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0"><i class="bi bi-cart-plus"></i> Thêm Sản Phẩm/Món Ăn</h5>
                </div>
                <div class="card-body">
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="bi bi-exclamation-triangle"></i> @TempData["Error"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }
                    <form asp-action="AddDetail" method="post" class="row g-3 align-items-end">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="MaHDB" value="@Model.MaHDB" />
                        
                        <div class="col-md-5">
                            <label class="form-label fw-bold">Chọn Sản Phẩm</label>
                            <select name="MaSP" class="form-select" asp-items="ViewBag.MaSP" required>
                                <option value="">-- Chọn Món --</option>
                            </select>
                        </div>
                        
                        <div class="col-md-2">
                            <label class="form-label fw-bold">Số Lượng</label>
                            <input type="number" name="SoLuong" class="form-control" value="1" min="1" required />
                        </div>

                        <div class="col-md-3">
                            <label class="form-label fw-bold">Khuyến Mãi (VNĐ)</label>
                            <input type="number" name="KhuyenMai" class="form-control" value="0" min="0" step="1000" />
                        </div>

                        <div class="col-md-2">
                            <button type="submit" class="btn btn-success w-100"><i class="bi bi-plus-lg"></i> Thêm</button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0"><i class="bi bi-list-ul"></i> Danh Sách Chi Tiết</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-secondary">
                                <tr>
                                    <th>Mã SP</th>
                                    <th>Tên Sản Phẩm</th>
                                    <th class="text-center">SL</th>
                                    <th class="text-end">Khuyến Mãi</th>
                                    <th class="text-end">Thành Tiền</th>
                                    <th class="text-center">Xóa</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.ChiTietHoaDonBans != null && Model.ChiTietHoaDonBans.Any())
                                {
                                    @foreach (var detail in Model.ChiTietHoaDonBans)
                                    {
                                        <tr>
                                            <td>@detail.MaSP</td>
                                            <td>@detail.TenSP</td>
                                            <td class="text-center">@detail.SoLuong</td>
                                            <td class="text-end text-muted">- @(detail.KhuyenMai?.ToString("N0") ?? "0")</td>
                                            <td class="text-end fw-bold">@(detail.ThanhTien?.ToString("N0") ?? "0") VNĐ</td>
                                            <td class="text-center">
                                                <form asp-action="RemoveDetail" method="post">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="MaHDB" value="@detail.MaHDB" />
                                                    <input type="hidden" name="MaSP" value="@detail.MaSP" />
                                                    <button type="submit" class="btn btn-link text-danger p-0" onclick="return confirm('Xóa món này?')">
                                                        <i class="bi bi-x-circle-fill"></i>
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="6" class="text-center py-4 text-muted italic">
                                            <i class="bi bi-info-circle"></i> Chưa có món nào được thêm vào hóa đơn.
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
