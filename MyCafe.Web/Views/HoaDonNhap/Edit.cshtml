@model MyCafe.Web.Models.HoaDonNhap

@{
    ViewData["Title"] = "Cập Nhật Chi Tiết Nhập Hàng";
}

<div class="container-fluid mt-4">
    <div class="row">
        <!-- Master Info -->
        <div class="col-md-4">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-info-circle"></i> Thông Tin Hóa Đơn Nhập</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <input type="hidden" asp-for="MaHDN" />
                        
                        <div class="mb-3">
                            <label class="form-label fw-bold">Số HĐ Nhập</label>
                            <input class="form-control bg-light" value="@Model.MaHDN" disabled />
                        </div>

                        <div class="mb-3">
                            <label asp-for="NgayNhap" class="form-label fw-bold">Ngày Nhập</label>
                            <input asp-for="NgayNhap" type="date" class="form-control" />
                            <span asp-validation-for="NgayNhap" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="MaNV" class="form-label fw-bold">Nhân Viên</label>
                            <select asp-for="MaNV" class="form-select" asp-items="ViewBag.MaNV"></select>
                            <span asp-validation-for="MaNV" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="MaNCC" class="form-label fw-bold">Nhà Cung Cấp</label>
                            <select asp-for="MaNCC" class="form-select" asp-items="ViewBag.MaNCC"></select>
                            <span asp-validation-for="MaNCC" class="text-danger"></span>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary">Cập Nhật Thông Tin Chung</button>
                        </div>
                    </form>
                </div>
                <div class="card-footer bg-light">
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="fw-bold">TỔNG NHẬP:</span>
                        <span class="text-primary fw-bold fs-4">@(Model.TongTien?.ToString("N0") ?? "0") VNĐ</span>
                    </div>
                </div>
            </div>
            <a asp-action="Index" class="btn btn-secondary w-100"><i class="bi bi-arrow-left"></i> Quay Lại Danh Sách</a>
        </div>

        <!-- Detail Management -->
        <div class="col-md-8">
            <div class="card shadow-sm mb-4 border-primary">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-plus-square"></i> Nhập Thêm Sản Phẩm</h5>
                </div>
                <div class="card-body bg-light">
                    <form asp-action="AddDetail" method="post" class="row g-3 align-items-end">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="MaHDN" value="@Model.MaHDN" />
                        
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Chọn Sản Phẩm</label>
                            <select name="MaSP" class="form-select" asp-items="ViewBag.MaSP" required>
                                <option value="">-- Chọn Sản Phẩm --</option>
                            </select>
                        </div>
                        
                        <div class="col-md-2">
                            <label class="form-label fw-bold">Số Lượng</label>
                            <input type="number" name="SoLuong" class="form-control" value="1" min="1" required />
                        </div>

                        <div class="col-md-2">
                            <label class="form-label fw-bold">Đơn Giá Nhập</label>
                            <input type="number" name="DonGia" class="form-control" value="0" min="0" step="500" required />
                        </div>

                        <div class="col-md-2">
                            <label class="form-label fw-bold">Khuyến Mãi</label>
                            <input type="number" name="KhuyenMai" class="form-control" value="0" min="0" step="1000" />
                        </div>

                        <div class="col-md-2">
                            <button type="submit" class="btn btn-primary w-100 fw-bold"><i class="bi bi-plus-lg"></i> NHẬP</button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0"><i class="bi bi-list-check"></i> Chi Tiết Các Mặt Hàng Đã Nhập</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-secondary">
                                <tr>
                                    <th>Mã SP</th>
                                    <th>Tên Sản Phẩm</th>
                                    <th class="text-center">Số Lượng</th>
                                    <th class="text-end">Đơn Giá</th>
                                    <th class="text-end">Khuyến Mãi</th>
                                    <th class="text-end">Thành Tiền</th>
                                    <th class="text-center">Xóa</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.ChiTietHoaDonNhaps != null && Model.ChiTietHoaDonNhaps.Any())
                                {
                                    @foreach (var detail in Model.ChiTietHoaDonNhaps)
                                    {
                                        <tr>
                                            <td>@detail.MaSP</td>
                                            <td>@detail.Sanpham?.TenSP</td>
                                            <td class="text-center">@detail.SoLuong</td>
                                            <td class="text-end">@(detail.DonGia?.ToString("N0") ?? "0")</td>
                                            <td class="text-end">@(detail.KhuyenMai?.ToString("N0") ?? "0")</td>
                                            <td class="text-end fw-bold text-primary">@(detail.ThanhTien?.ToString("N0") ?? "0") VNĐ</td>
                                            <td class="text-center">
                                                <form asp-action="RemoveDetail" method="post">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="MaHDN" value="@detail.MaHDN" />
                                                    <input type="hidden" name="MaSP" value="@detail.MaSP" />
                                                    <button type="submit" class="btn btn-outline-danger btn-sm" onclick="return confirm('Xóa dòng nhập này?')">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="7" class="text-center py-4 text-muted italic">
                                            <i class="bi bi-info-circle"></i> Chưa có sản phẩm nào trong lô hàng này.
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
