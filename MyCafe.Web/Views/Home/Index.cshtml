@{
    ViewData["Title"] = "Bảng Điều Khiển";
}

<div class="container-fluid">
    <!-- Header Section -->
    <div class="row pb-4 mb-3">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h1 class="display-5 fw-bold mb-2"><i class="bi bi-speedometer2"></i> Bảng Điều Khiển</h1>
                    <p class="lead text-muted mb-0">Chào mừng bạn! Dưới đây là tóm tắt hoạt động hôm nay.</p>
                </div>
                <div class="text-end">
                    <small class="text-muted d-block">@DateTime.Now.ToString("dddd, dd/MM/yyyy")</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Stats Cards Row 1 -->
    <div class="row g-4 mb-5">
        <div class="col-md-6 col-lg-3">
            <div class="card stat-card shadow-sm h-100 border-0">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div class="flex-grow-1">
                            <p class="text-uppercase mb-2 fw-bold" style="opacity: 0.8; font-size: 0.85rem;">Sản Phẩm</p>
                            <h2 class="mb-0 fw-bold">@ViewBag.ProductCount</h2>
                        </div>
                        <div class="text-end" style="opacity: 0.3;">
                            <i class="bi bi-box-seam" style="font-size: 3rem;"></i>
                        </div>
                    </div>
                </div>
                <div class="card-footer" style="background: rgba(255,255,255,0.1) !important; border: none !important;">
                    <a asp-controller="Sanpham" asp-action="Index" class="text-white text-decoration-none small fw-600">
                        Xem chi tiết <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-3">
            <div class="card stat-card shadow-sm h-100 border-0">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div class="flex-grow-1">
                            <p class="text-uppercase mb-2 fw-bold" style="opacity: 0.8; font-size: 0.85rem;">Doanh Thu</p>
                            <h2 class="mb-0 fw-bold">@(ViewBag.TotalSales.ToString("N0")) ₫</h2>
                        </div>
                        <div class="text-end" style="opacity: 0.3;">
                            <i class="bi bi-currency-dollar" style="font-size: 3rem;"></i>
                        </div>
                    </div>
                </div>
                <div class="card-footer" style="background: rgba(255,255,255,0.1) !important; border: none !important;">
                    <a asp-controller="HoaDonBan" asp-action="Index" class="text-white text-decoration-none small fw-600">
                        Lịch sử bán hàng <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-3">
            <div class="card stat-card shadow-sm h-100 border-0">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div class="flex-grow-1">
                            <p class="text-uppercase mb-2 fw-bold" style="opacity: 0.8; font-size: 0.85rem;">Nhân Viên</p>
                            <h2 class="mb-0 fw-bold">@ViewBag.StaffCount</h2>
                        </div>
                        <div class="text-end" style="opacity: 0.3;">
                            <i class="bi bi-people" style="font-size: 3rem;"></i>
                        </div>
                    </div>
                </div>
                <div class="card-footer" style="background: rgba(255,255,255,0.1) !important; border: none !important;">
                    <a asp-controller="NhanVien" asp-action="Index" class="text-white text-decoration-none small fw-600">
                        Quản lý đội ngũ <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-3">
            <div class="card stat-card shadow-sm h-100 border-0">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div class="flex-grow-1">
                            <p class="text-uppercase mb-2 fw-bold" style="opacity: 0.8; font-size: 0.85rem;">Đơn Hàng</p>
                            <h2 class="mb-0 fw-bold">@ViewBag.InvoiceCount</h2>
                        </div>
                        <div class="text-end" style="opacity: 0.3;">
                            <i class="bi bi-receipt" style="font-size: 3rem;"></i>
                        </div>
                    </div>
                </div>
                <div class="card-footer" style="background: rgba(255,255,255,0.1) !important; border: none !important;">
                    <a asp-controller="HoaDonBan" asp-action="Index" class="text-white text-decoration-none small fw-600">
                        Xem tất cả <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Content Row -->
    <div class="row g-4">
        <!-- Quick Actions -->
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white border-bottom" style="padding: 1.25rem;">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-lightning"></i> Thao Tác Nhanh</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-6 col-md-3">
                            <a asp-controller="HoaDonBan" asp-action="Create" class="btn btn-lg w-100 py-4 border-2 border-success text-success bg-transparent hover-shadow" style="transition: all 0.3s ease;">
                                <i class="bi bi-cart-plus d-block mb-2" style="font-size: 1.75rem;"></i>
                                <span class="fw-600">Bán Hàng</span>
                            </a>
                        </div>
                        <div class="col-6 col-md-3">
                            <a asp-controller="HoaDonNhap" asp-action="Create" class="btn btn-lg w-100 py-4 border-2 border-info text-info bg-transparent hover-shadow" style="transition: all 0.3s ease;">
                                <i class="bi bi-bag-plus d-block mb-2" style="font-size: 1.75rem;"></i>
                                <span class="fw-600">Nhập Hàng</span>
                            </a>
                        </div>
                        <div class="col-6 col-md-3">
                            <a asp-controller="Sanpham" asp-action="Create" class="btn btn-lg w-100 py-4 border-2 border-warning text-warning bg-transparent hover-shadow" style="transition: all 0.3s ease;">
                                <i class="bi bi-plus-square d-block mb-2" style="font-size: 1.75rem;"></i>
                                <span class="fw-600">Thêm Món</span>
                            </a>
                        </div>
                        <div class="col-6 col-md-3">
                            <a asp-controller="KhachHang" asp-action="Create" class="btn btn-lg w-100 py-4 border-2 border-primary text-primary bg-transparent hover-shadow" style="transition: all 0.3s ease;">
                                <i class="bi bi-person-plus d-block mb-2" style="font-size: 1.75rem;"></i>
                                <span class="fw-600">Thêm KH</span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Statistics Section -->
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white border-bottom" style="padding: 1.25rem;">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-graph-up"></i> Thống Kê Hôm Nay</h5>
                </div>
                <div class="card-body">
                    <div class="row text-center g-3">
                        <div class="col-md-4">
                            <div class="p-3">
                                <h6 class="text-muted mb-2 text-uppercase fw-bold">Tổng Bán</h6>
                                <h2 class="fw-bold text-success">@(ViewBag.TotalSales.ToString("N0")) ₫</h2>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="p-3 border-start border-end">
                                <h6 class="text-muted mb-2 text-uppercase fw-bold">Số Hóa Đơn</h6>
                                <h2 class="fw-bold text-info">@ViewBag.InvoiceCount</h2>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="p-3">
                                <h6 class="text-muted mb-2 text-uppercase fw-bold">Sản Phẩm</h6>
                                <h2 class="fw-bold text-primary">@ViewBag.ProductCount</h2>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Notifications & Info -->
        <div class="col-lg-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white border-bottom" style="padding: 1.25rem;">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-bell"></i> Thông Báo Hệ Thống</h5>
                </div>
                <div class="card-body p-0">
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item border-0 py-3 px-3 d-flex">
                            <div class="badge bg-info me-3 mt-1"><i class="bi bi-info-circle"></i></div>
                            <div>
                                <p class="mb-1 fw-600">Hệ Thống Sẵn Sàng</p>
                                <small class="text-muted">Hệ thống đã sẵn sàng cho ngày làm việc mới.</small>
                            </div>
                        </li>
                        <li class="list-group-item border-0 py-3 px-3 d-flex border-top">
                            <div class="badge bg-success me-3 mt-1"><i class="bi bi-check-circle"></i></div>
                            <div>
                                <p class="mb-1 fw-600">Sao Lưu Dữ Liệu</p>
                                <small class="text-muted">Đã sao lưu dữ liệu lúc 00:00 sáng nay.</small>
                            </div>
                        </li>
                        <li class="list-group-item border-0 py-3 px-3 d-flex border-top">
                            <div class="badge bg-warning me-3 mt-1"><i class="bi bi-exclamation-triangle"></i></div>
                            <div>
                                <p class="mb-1 fw-600">Kiểm Tra Tồn Kho</p>
                                <small class="text-muted">2 mặt hàng sắp hết, vui lòng nhập hàng.</small>
                            </div>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .hover-shadow:hover {
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15) !important;
    }
</style>
