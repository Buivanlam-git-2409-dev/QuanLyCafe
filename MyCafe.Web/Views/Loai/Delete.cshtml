@model MyCafe.Web.Models.Loai

@{
    ViewData["Title"] = "Xác Nhận Xóa Loại Sản Phẩm";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-6 offset-md-3">
            <div class="card shadow-sm border-danger">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0"><i class="bi bi-exclamation-triangle"></i> @ViewData["Title"]</h4>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning">
                        Bạn có chắc chắn muốn xóa loại sản phẩm này không? Hành động này không thể hoàn tác.
                    </div>
                    
                    <dl class="row mt-3">
                        <dt class="col-sm-4 fw-bold text-muted">Mã Loại:</dt>
                        <dd class="col-sm-8 fw-bold">@Html.DisplayFor(model => model.MaLoai)</dd>

                        <dt class="col-sm-4 fw-bold text-muted">Tên Loại:</dt>
                        <dd class="col-sm-8">@Html.DisplayFor(model => model.TenLoai)</dd>
                    </dl>
                    
                    <form asp-action="Delete" class="mt-4 d-flex justify-content-between">
                        <input type="hidden" asp-for="MaLoai" />
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-arrow-left"></i> Quay Lại
                        </a>
                        <button type="submit" class="btn btn-danger shadow">
                            <i class="bi bi-trash"></i> Xác Nhận Xóa
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
