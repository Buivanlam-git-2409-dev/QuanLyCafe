@model IEnumerable<MyCafe.Web.Models.Loai>

@{
    ViewData["Title"] = "Quản Lý Loại Sản Phẩm";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1><i class="bi bi-tags"></i> @ViewData["Title"]</h1>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="Create" class="btn btn-primary shadow-sm">
                <i class="bi bi-plus-lg"></i> Thêm Loại Mới
            </a>
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>Mã Loại</th>
                                <th>Tên Loại Sản Phẩm</th>
                                <th class="text-center">Hành Động</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td><strong>@Html.DisplayFor(modelItem => item.MaLoai)</strong></td>
                                    <td>@Html.DisplayFor(modelItem => item.TenLoai)</td>
                                    <td class="text-center">
                                        <div class="btn-group" role="group">
                                            <a asp-action="Details" asp-route-id="@item.MaLoai" class="btn btn-sm btn-info" title="Chi Tiết">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <a asp-action="Edit" asp-route-id="@item.MaLoai" class="btn btn-sm btn-warning" title="Chỉnh Sửa">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.MaLoai" class="btn btn-sm btn-danger" title="Xóa">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info shadow-sm" role="alert">
            <i class="bi bi-info-circle"></i> Chưa có loại sản phẩm nào trong hệ thống.
        </div>
    }
</div>
