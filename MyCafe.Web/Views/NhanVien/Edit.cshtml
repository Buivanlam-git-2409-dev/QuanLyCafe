@model MyCafe.Web.Models.NhanVien

@{
    ViewData["Title"] = "Chỉnh Sửa Thông Tin Nhân Viên";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card shadow">
                <div class="card-header bg-warning text-dark">
                    <h3 class="mb-0"><i class="bi bi-pencil-square"></i> @ViewData["Title"]</h3>
                </div>
                <div class="card-body">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <input type="hidden" asp-for="MaNV" />

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Mã Nhân Viên</label>
                                <input class="form-control bg-light" value="@Model.MaNV" disabled />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="TenNV" class="form-label fw-bold">Họ Và Tên</label>
                                <input asp-for="TenNV" class="form-control" />
                                <span asp-validation-for="TenNV" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="GioiTinh" class="form-label fw-bold">Giới Tính</label>
                                <select asp-for="GioiTinh" class="form-select">
                                    <option value="Nam">Nam</option>
                                    <option value="Nữ">Nữ</option>
                                    <option value="Khác">Khác</option>
                                </select>
                                <span asp-validation-for="GioiTinh" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="NgaySinh" class="form-label fw-bold">Ngày Sinh</label>
                                <input asp-for="NgaySinh" type="date" class="form-control" value="@(Model.NgaySinh.HasValue ? Model.NgaySinh.Value.ToString("yyyy-MM-dd") : "")" />                                <span asp-validation-for="NgaySinh" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="SDT" class="form-label fw-bold">Số Điện Thoại</label>
                                <input asp-for="SDT" class="form-control" />
                                <span asp-validation-for="SDT" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="MaQue" class="form-label fw-bold">Quê Quán</label>
                                <select asp-for="MaQue" class="form-select" asp-items="ViewBag.MaQue"></select>
                                <span asp-validation-for="MaQue" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="DiaChi" class="form-label fw-bold">Địa Chỉ Thường Trú</label>
                            <textarea asp-for="DiaChi" class="form-control" rows="2">@Model.DiaChi</textarea>
                            <span asp-validation-for="DiaChi" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                            <a asp-action="Index" class="btn btn-secondary me-md-2">Quay Lại</a>
                            <button type="submit" class="btn btn-warning px-4">Cập Nhật Thông Tin</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
