@model MyCafe.Web.Models.Que

@{
    ViewData["Title"] = "Thêm Quê Quán Mới";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-6 offset-md-3">
            <h1>@ViewData["Title"]</h1>
            <hr />

            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-group mb-3">
                    <label asp-for="MaQue" class="form-label">Mã Quê <span class="text-danger">*</span></label>
                    <input asp-for="MaQue" class="form-control" />
                    <span asp-validation-for="MaQue" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="TenQue" class="form-label">Tên Quê <span class="text-danger">*</span></label>
                    <input asp-for="TenQue" class="form-control" />
                    <span asp-validation-for="TenQue" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <button type="submit" class="btn btn-success me-2">
                        <i class="bi bi-check-lg"></i> Thêm Mới
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Quay Lại
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
