@model MyCafe.Web.Models.Sanpham

@{
    ViewData["Title"] = "Thêm Sản Phẩm Mới";
}

<div class="container-fluid px-4">
    <div class="row">
        <div class="col-lg-8 offset-lg-2">
            <div class="mb-4">
                <div>
                    <h1 class="h2 fw-bold mb-1"><i class="bi bi-plus-circle me-2"></i>@ViewData["Title"]</h1>
                    <p class="text-muted">Điền thông tin đầy đủ để thêm sản phẩm mới vào hệ thống</p>
                </div>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <form asp-action="Create" method="post" enctype="multipart/form-data">
                        <!-- Validation Summary -->
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 mb-4" role="alert" style="display:none;">
                            <i class="bi bi-exclamation-circle me-2"></i>
                            <strong>Lỗi</strong>
                            <div>Vui lòng kiểm tra các lỗi dưới đây</div>
                        </div>

                        <!-- Basic Info -->
                        <div class="mb-4 pb-4 border-bottom">
                            <h5 class="fw-bold mb-3"><i class="bi bi-info-circle me-2"></i>Thông Tin Cơ Bản</h5>

                            <div class="form-group mb-3">
                                <label asp-for="MaSP" class="form-label fw-600">Mã Sản Phẩm <span class="text-danger">*</span></label>
                                <input asp-for="MaSP" class="form-control form-control-lg" placeholder="VD: SP001" />
                                <span asp-validation-for="MaSP" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <div class="form-group mb-3">
                                <label asp-for="TenSP" class="form-label fw-600">Tên Sản Phẩm <span class="text-danger">*</span></label>
                                <input asp-for="TenSP" class="form-control form-control-lg" placeholder="VD: Cà Phê Đen" />
                                <span asp-validation-for="TenSP" class="text-danger small mt-1 d-block"></span>
                            </div>
                        </div>

                        <!-- Classification -->
                        <div class="mb-4 pb-4 border-bottom">
                            <h5 class="fw-bold mb-3"><i class="bi bi-tags me-2"></i>Phân Loại</h5>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group mb-3">
                                        <label asp-for="MaLoai" class="form-label fw-600">Loại <span class="text-danger">*</span></label>
                                        <select asp-for="MaLoai" class="form-select form-select-lg" asp-items="ViewBag.MaLoai">
                                            <option value="">-- Chọn Loại --</option>
                                        </select>
                                        <span asp-validation-for="MaLoai" class="text-danger small mt-1 d-block"></span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group mb-3">
                                        <label asp-for="MaCongDung" class="form-label fw-600">Công Dụng <span class="text-danger">*</span></label>
                                        <select asp-for="MaCongDung" class="form-select form-select-lg" asp-items="ViewBag.MaCongDung">
                                            <option value="">-- Chọn Công Dụng --</option>
                                        </select>
                                        <span asp-validation-for="MaCongDung" class="text-danger small mt-1 d-block"></span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Pricing -->
                        <div class="mb-4 pb-4 border-bottom">
                            <h5 class="fw-bold mb-3"><i class="bi bi-currency-dollar me-2"></i>Giá Cả</h5>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group mb-3">
                                        <label asp-for="GiaNhap" class="form-label fw-600">Giá Nhập (VNĐ)</label>
                                        <input asp-for="GiaNhap" class="form-control form-control-lg" type="number" step="0.01" placeholder="0" />
                                        <span asp-validation-for="GiaNhap" class="text-danger small mt-1 d-block"></span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group mb-3">
                                        <label asp-for="GiaBan" class="form-label fw-600">Giá Bán (VNĐ) <span class="text-danger">*</span></label>
                                        <input asp-for="GiaBan" class="form-control form-control-lg" type="number" step="0.01" placeholder="0" />
                                        <span asp-validation-for="GiaBan" class="text-danger small mt-1 d-block"></span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Inventory & Media -->
                        <div class="mb-4 pb-4 border-bottom">
                            <h5 class="fw-bold mb-3"><i class="bi bi-box2 me-2"></i>Tồn Kho & Hình Ảnh</h5>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group mb-3">
                                        <label asp-for="SoLuong" class="form-label fw-600">Số Lượng</label>
                                        <input asp-for="SoLuong" class="form-control form-control-lg" type="number" placeholder="0" />
                                        <span asp-validation-for="SoLuong" class="text-danger small mt-1 d-block"></span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group mb-3">
                                        <label for="hinhanh" class="form-label fw-600">Hình Ảnh</label>
                                        <input type="file" id="hinhanh" name="hinhanh" class="form-control form-control-lg" accept="image/*" />
                                        <small class="text-muted">Chấp nhận: JPG, PNG, GIF (tối đa 5MB)</small>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Actions -->
                        <div class="form-group d-flex gap-2">
                            <button type="submit" class="btn btn-primary btn-lg px-4">
                                <i class="bi bi-check-circle me-2"></i> Thêm Mới
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-4">
                                <i class="bi bi-arrow-left me-2"></i> Quay Lại
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
