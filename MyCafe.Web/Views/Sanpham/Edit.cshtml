@model MyCafe.Web.Models.Sanpham

@{
    ViewData["Title"] = "Chỉnh Sửa Sản Phẩm";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h1>@ViewData["Title"]</h1>
            <hr />

            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <input type="hidden" asp-for="MaSP" />
                <input type="hidden" asp-for="CreatedAt" />

                <div class="form-group mb-3">
                    <label asp-for="MaSP" class="form-label">Mã Sản Phẩm</label>
                    <input asp-for="MaSP" class="form-control" disabled />
                </div>

                <div class="form-group mb-3">
                    <label asp-for="TenSP" class="form-label">Tên Sản Phẩm <span class="text-danger">*</span></label>
                    <input asp-for="TenSP" class="form-control" />
                    <span asp-validation-for="TenSP" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="MaLoai" class="form-label">Loại <span class="text-danger">*</span></label>
                            <select asp-for="MaLoai" class="form-select" asp-items="ViewBag.MaLoai">
                                <option value="">-- Chọn Loại --</option>
                            </select>
                            <span asp-validation-for="MaLoai" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="MaCongDung" class="form-label">Công Dụng <span class="text-danger">*</span></label>
                            <select asp-for="MaCongDung" class="form-select" asp-items="ViewBag.MaCongDung">
                                <option value="">-- Chọn Công Dụng --</option>
                            </select>
                            <span asp-validation-for="MaCongDung" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="GiaNhap" class="form-label">Giá Nhập (VNĐ)</label>
                            <input asp-for="GiaNhap" class="form-control" type="number" step="0.01" />
                            <span asp-validation-for="GiaNhap" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="GiaBan" class="form-label">Giá Bán (VNĐ) <span class="text-danger">*</span></label>
                            <input asp-for="GiaBan" class="form-control" type="number" step="0.01" />
                            <span asp-validation-for="GiaBan" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="SoLuong" class="form-label">Số Lượng</label>
                    <input asp-for="SoLuong" class="form-control" type="number" />
                    <span asp-validation-for="SoLuong" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label for="hinhanh" class="form-label">Hình Ảnh</label>
                    <input type="file" id="hinhanh" name="hinhanh" class="form-control" accept="image/*" />
                    @if (Model.HinhAnh != null && Model.HinhAnh.Length > 0)
                    {
                        <small class="text-muted">Ảnh hiện tại: <img src="data:image/jpeg;base64,@Convert.ToBase64String(Model.HinhAnh)" style="max-height: 100px; margin-top: 10px;" /></small>
                    }
                </div>

                <div class="form-group">
                    <button type="submit" class="btn btn-primary me-2">
                        <i class="bi bi-check-lg"></i> Lưu Thay Đổi
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Quay Lại
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
