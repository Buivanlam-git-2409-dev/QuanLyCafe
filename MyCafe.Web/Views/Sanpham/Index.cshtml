@model IEnumerable<MyCafe.Web.Models.Sanpham>

@{
    ViewData["Title"] = "Quản Lý Sản Phẩm";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1>@ViewData["Title"]</h1>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-lg"></i> Thêm Sản Phẩm
            </a>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-6">
            <form asp-action="Index" method="get" class="input-group">
                <input type="text" name="searchString" class="form-control" placeholder="Tìm theo mã hoặc tên sản phẩm..." 
                       value="@ViewBag.SearchString" />
                <button type="submit" class="btn btn-outline-secondary">
                    <i class="bi bi-search"></i> Tìm Kiếm
                </button>
            </form>
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Mã SP</th>
                        <th>Tên Sản Phẩm</th>
                        <th>Loại</th>
                        <th>Công Dụng</th>
                        <th>Giá Nhập</th>
                        <th>Giá Bán</th>
                        <th>Số Lượng</th>
                        <th class="text-center">Hành Động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><strong>@Html.DisplayFor(modelItem => item.MaSP)</strong></td>
                            <td>@Html.DisplayFor(modelItem => item.TenSP)</td>
                            <td>@Html.DisplayFor(modelItem => item.Loai.TenLoai)</td>
                            <td>@Html.DisplayFor(modelItem => item.CongDung.TenCongDung)</td>
                            <td>@Html.DisplayFor(modelItem => item.GiaNhap)</td>
                            <td>@Html.DisplayFor(modelItem => item.GiaBan)</td>
                            <td>@Html.DisplayFor(modelItem => item.SoLuong)</td>
                            <td class="text-center">
                                <a asp-action="Details" asp-route-id="@item.MaSP" class="btn btn-sm btn-info" title="Chi Tiết">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@item.MaSP" class="btn btn-sm btn-warning" title="Chỉnh Sửa">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.MaSP" class="btn btn-sm btn-danger" title="Xóa">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info" role="alert">
            <i class="bi bi-info-circle"></i> Không có sản phẩm nào.
        </div>
    }
</div>
