@model IEnumerable<MyCafe.Web.Models.Sanpham>

@{
    ViewData["Title"] = "Quản Lý Sản Phẩm";
}

<div class="container-fluid px-4">
    <!-- Header Section -->
    <div class="row mb-4 align-items-center">
        <div class="col-md-8 mb-3">
            <div>
                <h1 class="h2 fw-bold mb-1"><i class="bi bi-box-seam me-2"></i>@ViewData["Title"]</h1>
                <p class="text-muted">Quản lý danh sách sản phẩm, giá cả và tồn kho</p>
            </div>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="Create" class="btn btn-primary shadow-sm">
                <i class="bi bi-plus-circle me-2"></i> Thêm Sản Phẩm
            </a>
        </div>
    </div>

    <!-- Search Bar -->
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <form asp-action="Index" method="get">
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0">
                        <i class="bi bi-search text-muted"></i>
                    </span>
                    <input type="text" name="searchString" class="form-control border-start-0" 
                           placeholder="Tìm theo mã hoặc tên sản phẩm..." 
                           value="@ViewBag.SearchString" />
                    <button type="submit" class="btn btn-outline-primary">
                        <i class="bi bi-search"></i> Tìm Kiếm
                    </button>
                </div>
            </form>
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="card shadow-sm border-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th class="border-bottom fw-bold text-uppercase">
                                <small>Mã SP</small>
                            </th>
                            <th class="border-bottom fw-bold text-uppercase">
                                <small>Tên Sản Phẩm</small>
                            </th>
                            <th class="border-bottom fw-bold text-uppercase">
                                <small>Loại</small>
                            </th>
                            <th class="border-bottom fw-bold text-uppercase">
                                <small>Công Dụng</small>
                            </th>
                            <th class="border-bottom fw-bold text-uppercase text-end">
                                <small>Giá Nhập</small>
                            </th>
                            <th class="border-bottom fw-bold text-uppercase text-end">
                                <small>Giá Bán</small>
                            </th>
                            <th class="border-bottom fw-bold text-uppercase text-end">
                                <small>Số Lượng</small>
                            </th>
                            <th class="border-bottom fw-bold text-uppercase text-center">
                                <small>Hành Động</small>
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold text-primary">@Html.DisplayFor(modelItem => item.MaSP)</td>
                                <td>
                                    <div class="fw-600">@Html.DisplayFor(modelItem => item.TenSP)</div>
                                </td>
                                <td>
                                    <span class="badge bg-info">@Html.DisplayFor(modelItem => item.Loai.TenLoai)</span>
                                </td>
                                <td>
                                    <small>@Html.DisplayFor(modelItem => item.CongDung.TenCongDung)</small>
                                </td>
                                <td class="text-end">
                                    <span class="text-muted">@Html.DisplayFor(modelItem => item.GiaNhap)</span>
                                </td>
                                <td class="text-end">
                                    <strong class="text-success">@Html.DisplayFor(modelItem => item.GiaBan) ₫</strong>
                                </td>
                                <td class="text-end">
                                    @{
                                        var quantity = (int)item.SoLuong;
                                        if (quantity <= 5)
                                        {
                                            <span class="badge bg-danger">@quantity</span>
                                        }
                                        else if (quantity <= 20)
                                        {
                                            <span class="badge bg-warning">@quantity</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">@quantity</span>
                                        }
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="btn-group btn-group-sm" role="group">
                                        <a asp-action="Details" asp-route-id="@item.MaSP" class="btn btn-light border" title="Chi Tiết">
                                            <i class="bi bi-eye text-info"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.MaSP" class="btn btn-light border" title="Chỉnh Sửa">
                                            <i class="bi bi-pencil text-warning"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.MaSP" class="btn btn-light border" title="Xóa">
                                            <i class="bi bi-trash text-danger"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info border-0 shadow-sm" role="alert">
            <div class="d-flex align-items-center">
                <i class="bi bi-info-circle me-3 fs-5"></i>
                <div>
                    <strong>Không có dữ liệu</strong>
                    <p class="mb-0 small mt-1">Hãy thêm sản phẩm mới để bắt đầu</p>
                </div>
            </div>
        </div>
    }
</div>
