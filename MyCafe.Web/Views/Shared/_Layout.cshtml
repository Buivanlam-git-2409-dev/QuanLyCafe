<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Cafe ChiChi</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MyCafe.Web.styles.css" asp-append-version="true" />
    <style>
        .navbar-brand { font-weight: bold; color: #6f4e37 !important; }
        .nav-link { font-weight: 500; }
        .dropdown-item i { margin-right: 10px; width: 20px; text-align: center; }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom shadow-sm mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-cup-hot-fill"></i> Cafe ChiChi
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Trang Chủ</a>
                        </li>
                        
                        <!-- Danh Mục Dropdown -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-dark" href="#" id="navbarDropdownDanhMuc" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Danh Mục
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="navbarDropdownDanhMuc">
                                <li><a class="dropdown-item" asp-controller="Sanpham" asp-action="Index"><i class="bi bi-box-seam"></i> Sản Phẩm</a></li>
                                <li><a class="dropdown-item" asp-controller="Loai" asp-action="Index"><i class="bi bi-tags"></i> Loại Sản Phẩm</a></li>
                                <li><a class="dropdown-item" asp-controller="CongDung" asp-action="Index"><i class="bi bi-info-circle"></i> Công Dụng</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" asp-controller="NhanVien" asp-action="Index"><i class="bi bi-people"></i> Nhân Viên</a></li>
                                <li><a class="dropdown-item" asp-controller="Que" asp-action="Index"><i class="bi bi-geo-alt"></i> Quê Quán</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" asp-controller="KhachHang" asp-action="Index"><i class="bi bi-person-badge"></i> Khách Hàng</a></li>
                                <li><a class="dropdown-item" asp-controller="NCC" asp-action="Index"><i class="bi bi-truck"></i> Nhà Cung Cấp</a></li>
                            </ul>
                        </li>

                        <!-- Nghiệp Vụ Dropdown -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-dark" href="#" id="navbarDropdownNghiepVu" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Nghiệp Vụ
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="navbarDropdownNghiepVu">
                                <li><a class="dropdown-item" asp-controller="HoaDonBan" asp-action="Index"><i class="bi bi-cart-check"></i> Hóa Đơn Bán</a></li>
                                <li><a class="dropdown-item" asp-controller="HoaDonNhap" asp-action="Index"><i class="bi bi-bag-plus"></i> Hóa Đơn Nhập</a></li>
                            </ul>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Bảo Mật</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container-fluid px-4">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-5 py-3 bg-light">
        <div class="container text-center">
            &copy; 2026 - Cafe ChiChi Management System - <i class="bi bi-code-slash"></i> with Love
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
