<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Cafe ChiChi</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MyCafe.Web.styles.css" asp-append-version="true" />
    <style>
        /* Remove conflicts from inline styles */
        body { margin-bottom: 0 !important; }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-cup-hot-fill"></i> Cafe ChiChi
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-lg-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index"><i class="bi bi-house-door me-1"></i> Trang Chủ</a>
                        </li>
                        
                        <!-- Danh Mục Dropdown -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="navbarDropdownDanhMuc" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-list me-1"></i> Danh Mục
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="navbarDropdownDanhMuc">
                                <li><a class="dropdown-item" asp-controller="Sanpham" asp-action="Index"><i class="bi bi-box-seam"></i> Sản Phẩm</a></li>
                                <li><a class="dropdown-item" asp-controller="Loai" asp-action="Index"><i class="bi bi-tags"></i> Loại Sản Phẩm</a></li>
                                <li><a class="dropdown-item" asp-controller="CongDung" asp-action="Index"><i class="bi bi-info-circle"></i> Công Dụng</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" asp-controller="NhanVien" asp-action="Index"><i class="bi bi-people"></i> Nhân Viên</a></li>
                                <li><a class="dropdown-item" asp-controller="Que" asp-action="Index"><i class="bi bi-geo-alt"></i> Quê Quán</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" asp-controller="KhachHang" asp-action="Index"><i class="bi bi-person-badge"></i> Khách Hàng</a></li>
                                <li><a class="dropdown-item" asp-controller="NCC" asp-action="Index"><i class="bi bi-truck"></i> Nhà Cung Cấp</a></li>
                            </ul>
                        </li>

                        <!-- Nghiệp Vụ Dropdown -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="navbarDropdownNghiepVu" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-receipt me-1"></i> Nghiệp Vụ
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="navbarDropdownNghiepVu">
                                <li><a class="dropdown-item" asp-controller="HoaDonBan" asp-action="Index"><i class="bi bi-cart-check"></i> Hóa Đơn Bán</a></li>
                                <li><a class="dropdown-item" asp-controller="HoaDonNhap" asp-action="Index"><i class="bi bi-bag-plus"></i> Hóa Đơn Nhập</a></li>
                            </ul>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Privacy"><i class="bi bi-shield-lock me-1"></i> Bảo Mật</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container-fluid px-4 mt-4">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="mt-5 py-4">
        <div class="container text-center">
            <p class="mb-0">&copy; 2026 Cafe ChiChi Management System <i class="bi bi-code-slash"></i> with <i class="bi bi-heart-fill" style="color: #d63031;"></i></p>
            <small>All Rights Reserved</small>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
